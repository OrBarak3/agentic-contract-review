# Choose which provider to use by default in Studio input.
DEFAULT_PROVIDER=openai

# Model names are deliberately configurable so the graph can be pointed at
# whatever current model ID you want without code changes.
OPENAI_MODEL=gpt-4.1-mini
GEMINI_MODEL=gemini-2.0-flash
GROK_MODEL=grok-3-mini

# Provider credentials.
OPENAI_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=

# Optional base URLs if you need them for proxies or compatible gateways.
OPENAI_BASE_URL=https://api.openai.com/v1
GROK_BASE_URL=https://api.x.ai/v1

# When true, the graph falls back to a deterministic heuristic extractor if
# the provider key is missing or the API call fails.
ALLOW_HEURISTIC_FALLBACK=true

# Checkpoint persistence for interrupt/resume.
# Use "sqlite" for durable local resume or "memory" for ephemeral test-only runs.
LANGGRAPH_CHECKPOINTER=sqlite

# API server settings (used when running api/main.py via uvicorn).
# Comma-separated list of allowed CORS origins.
# For production on Railway, set to your Vercel domain: https://yourdomain.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
